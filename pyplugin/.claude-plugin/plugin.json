{
  "name": "pyplugin",
  "version": "1.1.0",
  "description": "python plugin to creating endpoint, review module, and generate tests",
  "author": {
    "name": "JJS"
  },
  "install": {
    "copy": [
      { "from": ".claude/commands/", "to": ".claude/commands/" },
      { "from": ".claude/skills/",   "to": ".claude/skills/" },
      { "from": ".claude/agents/",   "to": ".claude/agents/" },
      { "from": "hooks/",            "to": "hooks/" },
      { "from": ".pre-commit-config.yaml", "to": ".pre-commit-config.yaml" }
    ],
    "merge": [
      { "file": ".claude/settings.json", "strategy": "deep_merge" }
    ]
  },
  "commands": [
    {
      "path": ".claude/commands/generate-endpoint.md"
    },
    {
      "path": ".claude/commands/generate-model.md"
    },
    {
      "path": ".claude/commands/generate-migration.md"
    },
    {
      "path": ".claude/commands/generate-test.md"
    },
    {
      "path": ".claude/commands/review-module.md"
    }
  ],
  "agents": [
    {
      "path": ".claude/agents/security-auditor.yaml"
    },
    {
      "path": ".claude/agents/db-reviewer.yaml"
    },
    {
      "path": ".claude/agents/test-coverage.yaml"
    }
  ],
  "skills": [
    {
      "path": ".claude/skills/python-best-practices/SKILL.md"
    },
    {
      "path": ".claude/skills/fastapi-patterns/SKILL.md"
    },
    {
      "path": ".claude/skills/sqlalchemy-patterns/SKILL.md"
    }
  ],
  "hooks": [
    {
      "path": ".claude/hooks/post-write-lint.yaml"
    }
  ],
  "permissions": {
    "allow": [
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(flake8:*)",
      "Bash(pytest:*)",
      "Bash(alembic:*)"
    ],
    "deny": ["Bash(rm -rf:*)"]
  }
}
